{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"]
    },
    "buildCommand": "pip install --upgrade pip && pip install -r service/requirements.txt"
  },
  "deploy": {
    "startCommand": "ASM_SERVICE_RUNTIME=1 uvicorn service.main:app --host 0.0.0.0 --port $PORT --workers 2",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
